{
	"name": "ultimate-multisite/ai-agent",
	"description": "Agentic AI loop for WordPress — chat with an AI that can call WordPress abilities (tools) autonomously.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"authors": [
		{
			"name": "Ultimate Multisite Community",
			"homepage": "https://ultimatemultisite.com"
		}
	],
	"require": {
		"php": ">=8.2",
		"automattic/jetpack-autoloader": "^3.0 || ^4.0 || ^5.0",
		"smalot/pdfparser": "^2.0",
		"wordpress/php-ai-client": "^1.2"
	},
	"require-dev": {
		"phpstan/phpstan": "^2.0",
		"phpunit/phpunit": "^9.6 || ^10.0",
		"szepeviktor/phpstan-wordpress": "^2.0",
		"yoast/phpunit-polyfills": "^3.0"
	},
	"autoload": {
		"psr-4": {
			"AiAgent\\": "includes/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"AiAgent\\Tests\\": "tests/AiAgent/"
		}
	},
	"config": {
		"allow-plugins": {
			"automattic/jetpack-autoloader": true
		},
		"preferred-install": "dist",
		"sort-packages": true
	},
	"homepage": "https://github.com/Ultimate-Multisite/ai-agent",
	"support": {
		"issues": "https://github.com/Ultimate-Multisite/ai-agent/issues",
		"source": "https://github.com/Ultimate-Multisite/ai-agent"
	}
}
